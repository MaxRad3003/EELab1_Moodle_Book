<quiz>
  <question type="multichoice"><name><text>Exp05 - ש1 - תדר תהודה</text></name><questiontext format="html"><text><![CDATA[<p dir="rtl">מהו הביטוי לתדר התהודה במעגל RLC אידיאלי?</p>]]></text></questiontext><defaultgrade>1</defaultgrade><single>true</single><shuffleanswers>true</shuffleanswers><answer fraction="100" format="html"><text><![CDATA[<p dir="rtl">f0 = 1/(2π√LC)</p>]]></text></answer><answer fraction="0" format="html"><text><![CDATA[<p dir="rtl">f0 = 2πLC</p>]]></text></answer><answer fraction="0" format="html"><text><![CDATA[<p dir="rtl">f0 = R/L</p>]]></text></answer></question>
  <question type="multichoice"><name><text>Exp05 - ש2 - רוחב פס</text></name><questiontext format="html"><text><![CDATA[<p dir="rtl">כיצד מוגדר רוחב הפס במעגל תהודה?</p>]]></text></questiontext><defaultgrade>1</defaultgrade><single>true</single><shuffleanswers>true</shuffleanswers><answer fraction="100" format="html"><text><![CDATA[<p dir="rtl">Δf = fH - fL</p>]]></text></answer><answer fraction="0" format="html"><text><![CDATA[<p dir="rtl">Δf = fH + fL</p>]]></text></answer><answer fraction="0" format="html"><text><![CDATA[<p dir="rtl">Δf = f0 / 2</p>]]></text></answer></question>
  <question type="multichoice"><name><text>Exp05 - ש3 - גורם טיב</text></name><questiontext format="html"><text><![CDATA[<p dir="rtl">מהו ביטוי מקובל לגורם הטיב מתוך מדידת רוחב פס?</p>]]></text></questiontext><defaultgrade>1</defaultgrade><single>true</single><shuffleanswers>true</shuffleanswers><answer fraction="100" format="html"><text><![CDATA[<p dir="rtl">Q = f0 / Δf</p>]]></text></answer><answer fraction="0" format="html"><text><![CDATA[<p dir="rtl">Q = Δf / f0</p>]]></text></answer><answer fraction="0" format="html"><text><![CDATA[<p dir="rtl">Q = fH + fL</p>]]></text></answer></question>
