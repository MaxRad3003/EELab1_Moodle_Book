<?xml version="1.0" encoding="UTF-8"?>
<quiz>
  <!-- Category Definition -->
  <question type="category">
    <category>
      <text>$course$/מעבדה לחשמל 1/ניסוי 1/משימת הכנה</text>
    </category>
  </question>

  <!-- Question 1: Resistor Color Code -->
  <question type="multichoice">
    <name>
      <text>ניסוי 1 - צופן צבעים - נגד 1.5k</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p dir="rtl">מהו רצף הצבעים של נגד בעל התנגדות של 1.5kΩ ודיוק של 5%?</p>]]></text>
    </questiontext>
    <defaultgrade>1.0</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <single>true</single>
    <shuffleanswers>true</shuffleanswers>
    <answernumbering>123</answernumbering>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="rtl">חום, ירוק, אדום, זהב</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p dir="rtl">נכון מאוד! חום (1), ירוק (5), אדום (10^2 = 100), זהב (5%). 15*100 = 1500 אוהם.</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">חום, ירוק, חום, זהב</p>]]></text>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">כתום, שחור, אדום, זהב</p>]]></text>
    </answer>
  </question>

  <!-- Question 2: DMM Voltage Measurement -->
  <question type="multichoice">
    <name>
      <text>ניסוי 1 - מדידת מתח - חיבור DMM</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p dir="rtl">כיצד יש לחבר את הרב-מודד (DMM) לצורך מדידת מתח על פני נגד במעגל?</p>]]></text>
    </questiontext>
    <defaultgrade>1.0</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <single>true</single>
    <shuffleanswers>true</shuffleanswers>
    <answernumbering>123</answernumbering>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="rtl">במקביל לנגד, מבלי לפתוח את המעגל.</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p dir="rtl">נכון! מתח נמדד בין שתי נקודות (הפרש פוטנציאלים), ולכן החיבור הוא במקביל.</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">בטור לנגד, תוך פתיחת המעגל.</p>]]></text>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">רק כאשר הספק כבוי, בחיבור מקבילי.</p>]]></text>
    </answer>
  </question>

  <!-- Question 3: Safety -->
  <question type="multichoice">
    <name>
      <text>ניסוי 1 - בטיחות - הפעלת מתח</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p dir="rtl">מתי מותר להפעיל את מקור המתח (ספק הכוח) במעגל שבניתם?</p>]]></text>
    </questiontext>
    <defaultgrade>1.0</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <single>true</single>
    <shuffleanswers>true</shuffleanswers>
    <answernumbering>123</answernumbering>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="rtl">רק לאחר בדיקת החיבורים על ידי המדריך וקבלת אישורו.</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p dir="rtl">בדיוק. זהו כלל בטיחות קריטי למניעת נזק לציוד ולסטודנטים.</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">מיד לאחר סיום החיווט על המטריצה.</p>]]></text>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">רק אם המתח נמוך מ-5V.</p>]]></text>
    </answer>
  </question>

  <!-- Question 4: Power Supply Series Mode -->
  <question type="multichoice">
    <name>
      <text>ניסוי 1 - ספק כוח - מצב SERIES</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p dir="rtl">בספק כוח המכוון למצב SERIES, כאשר MASTER מכוון ל-10V ו-SLAVE מכוון ל-5V, מה יהיה המתח המקסימלי שניתן לקבל בין ההדקים הקיצוניים?</p>]]></text>
    </questiontext>
    <defaultgrade>1.0</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <single>true</single>
    <shuffleanswers>true</shuffleanswers>
    <answernumbering>123</answernumbering>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="rtl">15V</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p dir="rtl">נכון! במצב טורי המתחים של שני המקורות מתחברים.</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">10V</p>]]></text>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">5V</p>]]></text>
    </answer>
  </question>

  <!-- Question 5: Breadboard Internal Connection -->
  <question type="multichoice">
    <name>
      <text>ניסוי 1 - מטריצה - חיבור פנימי</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p dir="rtl">כיצד מקושרים החורים ב"פסי הרכיבים" (הפסים המרכזיים) של המטריצה?</p>]]></text>
    </questiontext>
    <defaultgrade>1.0</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <single>true</single>
    <shuffleanswers>true</shuffleanswers>
    <answernumbering>123</answernumbering>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="rtl">כל 5 חורים בטור (אנכית) מקוצרים ביניהם.</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p dir="rtl">נכון. כל טור של 5 חורים מהווה צומת חשמלי אחד.</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">כל החורים לאורך השורה (אופקית) מקוצרים ביניהם.</p>]]></text>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">אין קשר פנימי, יש לחבר את כל החורים בחוטים חיצוניים.</p>]]></text>
    </answer>
  </question>

  <!-- Question 6: Current Limit Importance -->
  <question type="multichoice">
    <name>
      <text>ניסוי 1 - ספק כוח - הגבלת זרם</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p dir="rtl">מהי המטרה העיקרית של קביעת "הגבלת זרם" (Current Limit) בספק הכוח לפני חיבורו למעגל?</p>]]></text>
    </questiontext>
    <defaultgrade>1.0</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <single>true</single>
    <shuffleanswers>true</shuffleanswers>
    <answernumbering>123</answernumbering>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="rtl">למנוע זרם גבוה מדי שעלול לשרוף רכיבים במקרה של קצר.</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p dir="rtl">נכון מאוד. הגבלת הזרם היא מנגנון הגנה קריטי על רכיבי המעגל.</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">כדי להבטיח שהספק יעבוד תמיד במתח מקסימלי.</p>]]></text>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">אין צורך בהגבלה, הספק מתאים את עצמו אוטומטית לעומס.</p>]]></text>
    </answer>
  </question>

  <!-- Question 7: Tolerance Calculation -->
  <question type="multichoice">
    <name>
      <text>ניסוי 1 - נגדים - טולרנס</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p dir="rtl">לנגד בעל ערך נקוב של 100Ω יש טבעת זהב (5%). מהו טווח המדידה התקין עבור נגד זה?</p>]]></text>
    </questiontext>
    <defaultgrade>1.0</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <single>true</single>
    <shuffleanswers>true</shuffleanswers>
    <answernumbering>123</answernumbering>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="rtl">בין 95Ω ל-105Ω</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p dir="rtl">נכון. 5% מתוך 100 הם 5 אוהם, לכן הטווח הוא 100 פלוס/מינוס 5.</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">בין 90Ω ל-110Ω</p>]]></text>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">בדיוק 100Ω, כל סטייה מעידה על רכיב תקול.</p>]]></text>
    </answer>
  </question>

  <!-- Question 8: Ammeter Connection -->
  <question type="multichoice">
    <name>
      <text>ניסוי 1 - מדידת זרם - חיבור מד זרם</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p dir="rtl">כיצד יש לחבר את ה-DMM לצורך מדידת זרם הזורם דרך נגד?</p>]]></text>
    </questiontext>
    <defaultgrade>1.0</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <single>true</single>
    <shuffleanswers>true</shuffleanswers>
    <answernumbering>123</answernumbering>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="rtl">בטור לנגד, תוך "פתיחת" המעגל והעברת הזרם דרך המכשיר.</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p dir="rtl">נכון מאוד. מדידת זרם מחייבת שהאלקטרונים יעברו פיזית דרך המולטימטר.</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">במקביל לנגד, כפי שמודדים מתח.</p>]]></text>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p dir="rtl">ישירות להדקי ספק הכוח, מבלי להתחשב בשאר המעגל.</p>]]></text>
    </answer>
  </question>
</quiz>
